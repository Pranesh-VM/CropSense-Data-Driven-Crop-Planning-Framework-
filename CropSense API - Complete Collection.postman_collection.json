    {
      "name": "Planning (Phase 3)",
      "description": "Phase 3 Planning endpoints for crop comparison, risk analysis, and optimal rotation planning",
      "item": [
        {
          "name": "13. Compare Crop Trajectories",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"N\": 90,\n  \"P\": 42,\n  \"K\": 43,\n  \"soil_type\": \"loamy\",\n  \"season_index\": 0,\n  \"expected_rainfall_mm\": 600,\n  \"candidate_crops\": [\"rice\", \"wheat\", \"lentil\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/planning/compare-crops",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "planning",
                "compare-crops"
              ]
            },
            "description": "Compare look-ahead soil trajectories for candidate crops. Shows which crop leaves the soil in better condition for the next season.\n\nReturns:\n- immediate_reward: Profit from this crop cycle\n- future_value_estimate: Expected value of future seasons\n- total_estimated_value: immediate + future\n- next_state: Soil NPK after crop cycle"
          },
          "response": []
        },
        {
          "name": "14. Profit Risk Report (Monte Carlo)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"N\": 90,\n  \"P\": 42,\n  \"K\": 43,\n  \"soil_type\": \"loamy\",\n  \"expected_rainfall_mm\": 600,\n  \"candidate_crops\": [\"rice\", \"wheat\", \"lentil\"],\n  \"rainfall_uncertainty_pct\": 0.20,\n  \"price_uncertainty_pct\": 0.15\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/planning/profit-risk-report",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "planning",
                "profit-risk-report"
              ]
            },
            "description": "Monte Carlo profit distribution for candidate crops. Simulates 2000 future scenarios with varying rainfall and market price.\n\nReturns for each crop:\n- mean_profit: Average expected profit\n- min_profit / max_profit: Range\n- std_dev: Standard deviation\n- prob_of_loss: Probability of negative profit\n- percentile_5 / percentile_95: Confidence interval\n- risk_adjusted_score: Mean - StdDev (conservative estimate)"
          },
          "response": []
        },
        {
          "name": "15. Seasonal Rotation Plan (Q-Learning)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"N\": 90,\n  \"P\": 42,\n  \"K\": 43,\n  \"soil_type\": \"loamy\",\n  \"expected_rainfall_mm\": 600,\n  \"season_index\": 0,\n  \"num_seasons\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/planning/seasonal-rotation-plan",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "planning",
                "seasonal-rotation-plan"
              ]
            },
            "description": "Get optimal multi-season crop rotation from trained Q-Learning agent.\n\nReturns:\n- sequence: Optimal crop order (e.g., [\"rice\", \"lentil\", \"wheat\", \"mungbean\", \"rice\"])\n- total_reward: Sum of all season rewards\n- avg_reward_per_season: Mean reward\n- season_details: Per-season breakdown with soil states\n- final_soil_state: NPK after all seasons"
          },
          "response": []
        },
        {
          "name": "16. Train Q-Agent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"N\": 90,\n  \"P\": 42,\n  \"K\": 43,\n  \"soil_type\": \"loamy\",\n  \"expected_rainfall_mm\": 600,\n  \"num_episodes\": 1000,\n  \"crop_pool\": [\"rice\", \"wheat\", \"lentil\", \"maize\", \"mungbean\", \"chickpea\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/planning/train-q-agent",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "planning",
                "train-q-agent"
              ]
            },
            "description": "Trigger Q-Agent training. Takes ~30-60 seconds for 1000 episodes.\n\nCall this:\n- Once during initial setup\n- After every 3-5 completed crop cycles to incorporate real data\n\nParameters:\n- num_episodes: Training iterations (default: 1000)\n- crop_pool: Subset of crops to consider (default: all 22)\n\nReturns training stats and saves model to disk."
          },
          "response": []
        }
      ]
    },
