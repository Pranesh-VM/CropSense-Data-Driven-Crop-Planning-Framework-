          "name": "2. Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('auth_token', jsonData.token);",
                  "    pm.environment.set('farmer_id', jsonData.farmer.farmer_id);",
                  "    console.log('Token saved to environment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ramesh_farmer\",\n  \"email\": \"ramesh@example.com\",\n  \"password\": \"test123456\",\n  \"name\": \"Ramesh Kumar\",\n  \"phone\": \"+919876543210\",\n  \"location\": \"Chennai, Tamil Nadu\",\n  \"latitude\": 13.0827,\n  \"longitude\": 80.2707\n}"
