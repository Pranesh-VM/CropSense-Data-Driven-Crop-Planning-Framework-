    {
      "name": "RINDM Cycle",
      "item": [
        {
          "name": "5. Get Recommendations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('recommendation_id', jsonData.recommendation_id);",
                  "    pm.environment.set('recommended_crop', jsonData.recommendations.predicted_crop);",
                  "    console.log('Recommendation ID saved:', jsonData.recommendation_id);",
                  "    console.log('Recommended crop:', jsonData.recommendations.predicted_crop);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"N\": 90,\n  \"P\": 42,\n  \"K\": 43,\n  \"ph\": 6.5,\n  \"latitude\": 13.0827,\n  \"longitude\": 80.2707\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/rindm/get-recommendations",
              "host": [
